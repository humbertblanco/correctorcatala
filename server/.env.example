# =============================================================================
# Corrector Català — server config
# =============================================================================
# Copy this file to .env and edit. Two deployment modes are supported:
#
#  • Standalone (clean VPS, Docker owns 80/443):
#      use scripts/bootstrap.sh, which runs `docker compose --profile standalone up -d`
#
#  • Behind reverse proxy (Plesk, Cloudflare Tunnel, Traefik, k8s ingress…):
#      use `docker compose up -d`  (no profile) — runs only LanguageTool bound
#      to 127.0.0.1:${HOST_PORT}, and you proxy to it from your existing stack.
# =============================================================================

# Domain used in the standalone nginx + LE config. Ignored in proxy-fronted mode.
DOMAIN=api.corrector.cat

# Email used by Let's Encrypt for expiry warnings (standalone mode only).
EMAIL_FOR_LE=admin@example.com

# Where to bind the LT container's published port on the host.
# 127.0.0.1 = localhost-only (recommended for proxy-fronted mode)
# 0.0.0.0   = all interfaces (only if Docker is your edge layer)
HOST_BIND=127.0.0.1
HOST_PORT=8010

# JVM heap (LT comfortably runs Catalan-only on 1-2 GB)
JAVA_XMS=1g
JAVA_XMX=4g

# Optional: pin the LT image digest in production for reproducibility
# LANGUAGETOOL_IMAGE=erikvl87/languagetool@sha256:...
LANGUAGETOOL_IMAGE=erikvl87/languagetool:latest
